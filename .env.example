# ============================================
# 环境变量模板
# 复制为 .env.local 用于本地开发
# ============================================

# ============================================
# 基础配置
# ============================================
# Node 环境: development | production | test
NODE_ENV=development

# 应用环境: dev | test | prod
NEXT_PUBLIC_APP_ENV=dev

# 当前应用 ID（从 apps 表中获取）
NEXT_PUBLIC_APP_ID=your-app-uuid

# ============================================
# Supabase 配置
# ============================================
# Supabase 项目 URL (例如: https://xxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (客户端使用，权限受限)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (服务端使用，可绕过 RLS)
# ⚠️ 警告: 绝对不要暴露给客户端！
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase 项目 ID (用于 CLI)
SUPABASE_PROJECT_ID=your-project-id

# ============================================
# 支付配置 (可选)
# ============================================
# 微信支付
WECHAT_PAY_MCH_ID=your-mch-id
WECHAT_PAY_API_KEY=your-api-key
WECHAT_PAY_APP_ID=your-app-id

# 万里汇 (WorldFirst)
WORLDFIRST_API_KEY=your-api-key
WORLDFIRST_API_SECRET=your-api-secret

# ============================================
# 第三方登录配置 (可选)
# ============================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 微信登录
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret

# Apple Sign In
APPLE_CLIENT_ID=your-apple-client-id
APPLE_PRIVATE_KEY=your-apple-private-key

# ============================================
# 邮件/短信配置 (可选)
# ============================================
# SMTP 配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password

# Twilio SMS (用于短信验证码)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=your-twilio-phone

# ============================================
# 安全与加密
# ============================================
# 用于加密敏感数据的密钥 (至少 32 位)
ENCRYPTION_KEY=your-32-character-encryption-key

# JWT 密钥 (用于自定义 Token 签发，通常由 Supabase 管理)
JWT_SECRET=your-jwt-secret

# ============================================
# Vercel 部署配置
# ============================================
# Vercel Token (用于 CI/CD 部署)
VERCEL_TOKEN=your-vercel-token

# Vercel 组织/用户 ID
VERCEL_ORG_ID=your-vercel-org-id

# Vercel 项目 ID
VERCEL_PROJECT_ID=your-vercel-project-id

# ============================================
# 监控与日志 (可选)
# ============================================
# Sentry DSN (错误追踪)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# LogRocket (前端监控)
NEXT_PUBLIC_LOGROCKET_ID=your-logrocket-id

# ============================================
# 功能开关
# ============================================
# 是否启用 Realtime 订阅
NEXT_PUBLIC_ENABLE_REALTIME=true

# 是否启用支付功能
ENABLE_PAYMENT=true

# 是否启用团队功能
ENABLE_TEAM_FEATURES=true

# 是否启用发票功能
ENABLE_INVOICE=true
