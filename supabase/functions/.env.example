# ============================================
# Supabase Edge Functions 环境变量
# 这些变量将在 Edge Functions 中通过 Deno.env.get() 访问
# ============================================

# Supabase 配置
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 支付配置 (如需在 Edge Functions 处理支付回调)
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_APP_ID=

WORLDFIRST_API_KEY=
WORLDFIRST_API_SECRET=

# 第三方登录
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 加密密钥
ENCRYPTION_KEY=

# 功能开关
ENABLE_PAYMENT=true
ENABLE_TEAM_FEATURES=true